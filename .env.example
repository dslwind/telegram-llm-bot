TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
# Optional: OpenAI-compatible endpoint (leave empty for official OpenAI)
OPENAI_BASE_URL=
# Optional: System prompt
SYSTEM_PROMPT=You are a helpful Telegram assistant. Answer clearly and briefly.
# Number of user+assistant message pairs loaded from history
MAX_HISTORY_PAIRS=10
# SQLite path for persisted chat history
SQLITE_PATH=./data/chat_history.db
# Optional: comma-separated Telegram user IDs, empty means allow all
WHITELIST_USER_IDS=
# Per-user rate limit (requests inside window)
RATE_LIMIT_COUNT=20
RATE_LIMIT_WINDOW_SECONDS=60
# Streaming message edit behavior
STREAM_EDIT_INTERVAL_SECONDS=0.8
STREAM_MIN_CHARS_DELTA=24
